[{
    "os": "Instalación Windows 11",
    "ram": 4,
    "ncore": "",
    "mcore": 4,
    "ssd": "",
    "socket": "qWin2OnceInstall.unix",
    "isowin": "",
    "type": "installW11",
    "arq":"x64",
    "cmd":["qemu-system-x86_64",
    "--enable-kvm",
    "-m <-(ram)->G", 
    "-M q35,accel=kvm",
    "-cpu host",
    "-smp <-(mcore)-><-(ncore)->",
    "-drive if=pflash,format=raw,readonly=on,file=bios/<-(arq)->OVMF_CODE.secboot.fd",
    "-drive if=pflash,format=raw,file=bios/<-(arq)->OVMF_VARS.fd",
    "-drive file=disks/<-(ssd)->,index=0,media=disk,if=virtio,cache=unsafe",
    "-rtc base=localtime",
    "-device virtio-vga-gl -display gtk,gl=on -usb -device usb-tablet",
    "-net nic,model=virtio-net-pci",
    "-net user,hostfwd=tcp::3389-:3389",
    "-device intel-hda -audiodev pipewire,id=pwsnd -device hda-duplex,audiodev=pwsnd",
    "-device qemu-xhci,id=xhci",
    "-name \"<-(os)->\"",
    "-monitor unix:/tmp/<-(socket)->,server,nowait",
    "-drive file=<-(isowin)->,media=cdrom",
    "-drive file=drivers/virtio-win.iso,media=cdrom"]
},{
	"os": "Windows 11",
	"ram": 4,
	"ncore": "",
	"mcore": 4,
	"ssd": "ssd.qcow2",
	"socket": "qWin2Once.unix",
    "type": "installed",
    "arq":"x64",
	"cmd":["qemu-system-x86_64",
    "--enable-kvm",
    "-m <-(ram)->G", 
    "-M q35,accel=kvm",
    "-cpu host",
    "-smp <-(mcore)-><-(ncore)->",
    "-drive if=pflash,format=raw,readonly=on,file=bios/<-(arq)->OVMF_CODE.fd",
    "-drive if=pflash,format=raw,file=bios/<-(arq)->OVMF_VARS.fd",
    "-drive file=disks/<-(ssd)->,index=0,media=disk,if=virtio,cache=unsafe",
    "-rtc base=localtime",
    "-device virtio-vga-gl -display gtk,gl=on -usb -device usb-tablet",
    "-net nic,model=virtio-net-pci",
    "-net user,hostfwd=tcp::3389-:3389",
    "-device intel-hda -audiodev pipewire,id=pwsnd -device hda-duplex,audiodev=pwsnd",
    "-device qemu-xhci,id=xhci",
    "-name \"<-(os)->\"",
	"-monitor unix:/tmp/<-(socket)->,server,nowait"]
